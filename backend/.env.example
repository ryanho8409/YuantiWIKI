# 复制本文件为 .env 并填入真实值。不要将 .env 提交到版本库。

# 数据库连接（PostgreSQL）
DATABASE_URL="postgresql://用户名:密码@localhost:5432/数据库名"

# 影子库（migrate dev 时使用）。若数据库用户无建库权限，请先手动创建该库（如 yuantiwiki_shadow），再填此处
SHADOW_DATABASE_URL="postgresql://用户名:密码@localhost:5432/数据库名_shadow"

# 服务端口，默认 3000
PORT=3000

# JWT 签名密钥。必须使用随机字符串，且不要泄露。
# 生成方式（在项目根目录执行）：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="请替换为上述命令生成的一串十六进制字符"
